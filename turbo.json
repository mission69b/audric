{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_DEPLOYMENT_ID",
    "VERCEL_GIT_COMMIT_SHA",
    "VERCEL_OIDC_TOKEN",
    "ANTHROPIC_API_KEY",
    "BLOCKVISION_API_KEY",
    "DATABASE_URL",
    "ENOKI_SECRET_KEY",
    "T2000_INTERNAL_KEY",
    "SPONSOR_INTERNAL_KEY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "AGENT_MODEL",
    "AUDRIC_INTERNAL_API_URL",
    "BRAVE_API_KEY",
    "CRON_SECRET",
    "OPENAI_API_KEY",
    "ELEVENLABS_API_KEY",
    "ELEVENLABS_VOICE_ID",
    "RESEND_API_KEY",
    "INTERNAL_API_KEY",
    "SUI_RPC_URL",
    "SERVER_URL",
    "SYNTHETIC_SESSION_PREFIXES",
    "NEXT_PUBLIC_SUI_NETWORK",
    "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
    "NEXT_PUBLIC_ENOKI_API_KEY",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_GATEWAY_URL",
    "NEXT_PUBLIC_DEPLOYMENT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
