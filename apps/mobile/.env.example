# Audric mobile — public client config (NO secrets here; the client_secret lives
# only on the exchange server). Copy to .env.local and fill in.

# Google OAuth *Web* client id — MUST equal web-v3's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# This is the zkLogin `aud`; a different value forks the wallet.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Base URL of the token-exchange server (holds the client_secret). Phase 0 this
# is web-v3 itself (`pnpm --filter web-v3 dev`), whose native-auth routes live
# under /api/mobile-auth — so the base MUST include that path segment, else the
# app POSTs to /exchange (404) instead of /api/mobile-auth/exchange.
#   iOS simulator     -> http://localhost:3002/api/mobile-auth
#   Android emulator  -> http://localhost:3002/api/mobile-auth  (run: adb reverse tcp:3002 tcp:3002)
#   physical device   -> an https tunnel + /api/mobile-auth (see PHASE0_RUNBOOK.md)
EXPO_PUBLIC_EXCHANGE_BASE_URL=http://localhost:3002/api/mobile-auth

# --- AI (chat) ---------------------------------------------------------------
# SERVER-ONLY (no EXPO_PUBLIC_ prefix): the provider key is read only inside the
# Expo Router API route (app/api/chat+api.ts), never inlined into the client
# bundle. Mobile uses the Vercel AI Gateway (same provider path as web-v3's
# lib/ai/providers.ts, `gateway.languageModel`). Default model = Kimi K2.5 (free).
AI_GATEWAY_API_KEY=vck_...

# Absolute origin of the deployed chat API (PROD only). In dev this is derived
# from Expo's dev-server URL, so leave it unset locally.
# EXPO_PUBLIC_API_BASE_URL=https://api.audric.ai
