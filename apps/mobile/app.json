{
  "expo": {
    "name": "Audric",
    "slug": "audric",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "audric",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "ai.audric.app",
      "supportsTablet": false
    },
    "android": {
      "package": "ai.audric.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow Audric to use Face ID to unlock your wallet."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Audric to use Face ID to unlock the app."
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Audric to attach photos to a message.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
