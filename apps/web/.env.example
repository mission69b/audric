# ─── Required ────────────────────────────────────────────────
# Sui network: "mainnet" or "testnet"
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Google OAuth (zkLogin)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Enoki (zkLogin + gas sponsorship)
NEXT_PUBLIC_ENOKI_API_KEY=your-enoki-api-key
ENOKI_SECRET_KEY=your-enoki-secret-key

# Database (NeonDB / Postgres)
DATABASE_URL=postgres://user:password@host/dbname

# Gas sponsorship (t2000 server)
SPONSOR_INTERNAL_KEY=your-sponsor-key

# ─── Engine (Audric chat) ────────────────────────────────────
# Anthropic API key for the conversational engine
ANTHROPIC_API_KEY=sk-ant-...

# ─── Voice Mode (optional — feature is hidden if either is unset) ──
# Whisper STT (speech-to-text) — handles 99 languages, accents, slang,
# and crypto jargon ("vSUI", "haSUI", "NAVI") accurately. ~$0.36/hour
# of voice. Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ElevenLabs TTS (text-to-speech) — premium multilingual voices with
# word-level timestamps required for the Claude-style highlight UI.
# Free tier: 10k chars/month. ~$0.18-0.30/min after that.
# Get a key at https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=sk_...
# Voice ID — defaults to Rachel (warm, US English, multilingual model
# is auto-selected so this voice handles other languages too).
# Browse voices at https://elevenlabs.io/app/voice-library
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# LLM model (defaults to claude-sonnet-4-20250514)
# AGENT_MODEL=claude-sonnet-4-20250514

# Upstash Redis (session storage) — @upstash/redis reads these automatically
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Email (Resend) ──────────────────────────────────────────
# Email verification only. Critical-HF alerts (S.5/S.12/S.13) were removed
# in S.31 — stablecoin-only collateral + zkLogin tap-to-confirm makes
# proactive HF email net-negative UX. See t2000/audric-build-tracker.md.
RESEND_API_KEY=re_...

# ─── Internal infrastructure (t2000 ECS cron) ─────────────────
# Shared secret for t2000 cron internal API calls
# (`/api/internal/notification-users` + `/api/internal/health-factor` reads).
T2000_INTERNAL_KEY=your-t2000-internal-key

# ─── Vercel cron auth (TurnMetrics retention + pending sweep) ─
# Shared secret used by `app/api/cron/*/route.ts` to authenticate
# scheduled invocations. Vercel injects `Authorization: Bearer ${CRON_SECRET}`
# automatically when this env var is set in the project — same value
# powers both the `turn-metrics-cleanup` (daily 03:00 UTC) and the
# `turn-metrics-pending-sweep` ([v1.4.2] every 5 minutes) jobs.
# CRON_SECRET=your-cron-secret

# ─── TurnMetrics synthetic-traffic filter (v1.4.2 — Day 3) ────
# Comma-separated list of `sessionId` prefixes that mark a turn as
# bot/test traffic. Used by:
#   - `turn-metrics-pending-sweep` cron (excludes synthetic rows
#     from the timeout sweep — those don't have a UI loop, and
#     timing them out skews resolution-rate dashboards).
#   - The resume route's TurnMetrics row write (stamps
#     `synthetic: true` so dashboards can `WHERE synthetic = false`
#     when computing user-facing latency / cost p95s).
# Day-3 follow-up: configure the test harness to emit a stable
# prefix (e.g. `s_synthetic_` / `s_botcheck_`) so this list stays
# honest without manual updates whenever a new bot session lands.
# Empty / unset is safe: no sessions get marked synthetic.
# SYNTHETIC_SESSION_PREFIXES=s_synthetic_,s_botcheck_

# ─── Optional ────────────────────────────────────────────────
# BlockVision Sui RPC API key (paid private endpoint).
# When set, all server-side Sui RPC calls (engine tools, wallet refresh,
# payment verification, etc.) route through BlockVision instead of the public
# fullnode. Strongly recommended for production — public Sui mainnet RPC is
# heavily rate-limited and is the dominant source of read-tool p95 latency.
# Browser-side calls (PayButton) continue to use the public node.
# Resolves to: https://sui-<network>.blockvision.org/v1/<KEY>
# Get a key at https://dashboard.blockvision.org
# BLOCKVISION_API_KEY=your-blockvision-api-key

# Gateway URL (defaults to https://mpp.t2000.ai)
# NEXT_PUBLIC_GATEWAY_URL=https://mpp.t2000.ai

# Internal API key for service gateway auth
# INTERNAL_API_KEY=your-internal-key

# Server URL for gas station (defaults to https://api.t2000.ai)
# SERVER_URL=https://api.t2000.ai
