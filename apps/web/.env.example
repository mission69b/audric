# ─── Required ────────────────────────────────────────────────
# Sui network: "mainnet" or "testnet"
NEXT_PUBLIC_SUI_NETWORK=mainnet

# Google OAuth (zkLogin)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Enoki (zkLogin + gas sponsorship)
NEXT_PUBLIC_ENOKI_API_KEY=your-enoki-api-key
ENOKI_SECRET_KEY=your-enoki-secret-key

# Database (NeonDB / Postgres)
DATABASE_URL=postgres://user:password@host/dbname

# Gas sponsorship (t2000 server)
SPONSOR_INTERNAL_KEY=your-sponsor-key

# ─── Engine (Audric chat) ────────────────────────────────────
# Anthropic API key for the conversational engine
ANTHROPIC_API_KEY=sk-ant-...

# LLM model (defaults to claude-sonnet-4-20250514)
# AGENT_MODEL=claude-sonnet-4-20250514

# Upstash Redis (session storage) — @upstash/redis reads these automatically
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Email (Resend) ──────────────────────────────────────────
# Verification emails + critical health-factor alerts (HF < 1.2)
# Morning briefings, weekly digests, rate alerts, and copilot suggestions were
# retired in the April 2026 simplification. See t2000/audric-build-tracker.md S.0–S.12.
RESEND_API_KEY=re_...

# ─── Internal infrastructure (t2000 ECS cron + indexer) ──────
# Shared secret for t2000 cron + indexer internal API calls (e.g. HF alert hook)
T2000_INTERNAL_KEY=your-t2000-internal-key

# ─── Optional ────────────────────────────────────────────────
# BlockVision Sui RPC API key (paid private endpoint).
# When set, all server-side Sui RPC calls (engine tools, wallet refresh,
# payment verification, etc.) route through BlockVision instead of the public
# fullnode. Strongly recommended for production — public Sui mainnet RPC is
# heavily rate-limited and is the dominant source of read-tool p95 latency.
# Browser-side calls (PayButton) continue to use the public node.
# Get a key at https://dashboard.blockvision.org
# BLOCKVISION_API_KEY=your-blockvision-api-key

# Gateway URL (defaults to https://mpp.t2000.ai)
# NEXT_PUBLIC_GATEWAY_URL=https://mpp.t2000.ai

# Internal API key for service gateway auth
# INTERNAL_API_KEY=your-internal-key

# Server URL for gas station (defaults to https://api.t2000.ai)
# SERVER_URL=https://api.t2000.ai
