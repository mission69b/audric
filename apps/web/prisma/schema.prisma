generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  suiAddress       String    @unique
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  emailVerifyToken String?
  emailVerifyExpiry DateTime?
  displayName      String?
  timezoneOffset   Int       @default(0)
  tosAcceptedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  preferences          UserPreferences?
  conversationLogs     ConversationLog[]
  savingsGoals         SavingsGoal[]
  adviceLogs           AdviceLog[]
  payments             Payment[]
  watchAddresses       WatchAddress[]
  portfolioSnapshots   PortfolioSnapshot[]
  financialProfile     UserFinancialProfile?
  memories             UserMemory[]
  linkedWallets        LinkedWallet[]

  @@index([email])
  @@index([emailVerified, timezoneOffset])
}

model UserPreferences {
  address      String   @id
  contacts     Json     @default("[]")
  limits       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

model ConversationLog {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  role       String
  content    String
  toolCalls  Json?
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId])
}

model SessionUsage {
  id               String   @id @default(cuid())
  address          String
  sessionId        String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costUsd          Float    @default(0)
  toolNames        String[] @default([])
  model            String?
  createdAt        DateTime @default(now())

  @@index([address, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model ServicePurchase {
  id        String   @id @default(cuid())
  address   String
  serviceId String
  amountUsd Float
  productId String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  @@index([address, createdAt])
}

model SavingsGoal {
  id               String    @id @default(cuid())
  userId           String
  name             String
  emoji            String    @default("🎯")
  targetAmount     Float
  deadline         DateTime?
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  adviceLogs AdviceLog[]

  @@index([userId, status])
}

model AppEvent {
  id             String   @id @default(cuid())
  address        String
  type           String
  title          String
  details        Json?
  digest         String?
  adviceLogId    String?
  goalId         String?
  suiTxVerified  Boolean  @default(false)
  source         String   @default("chat")
  createdAt      DateTime @default(now())

  @@index([address, createdAt])
  @@index([address, type, createdAt])
  @@index([adviceLogId])
  @@index([goalId])
}

model AdviceLog {
  id            String       @id @default(cuid())
  userId        String
  sessionId     String
  adviceText    String
  adviceType    String
  targetAmount  Float?
  goalId        String?
  appEventId    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user           User           @relation(fields: [userId], references: [id])
  goal           SavingsGoal?   @relation(fields: [goalId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Payment {
  id          String    @id @default(cuid())
  slug        String    @unique
  nonce       String    @default(uuid())
  userId      String
  suiAddress  String

  type        String    @default("link")
  status      String    @default("active")
  amount      Float?
  currency    String    @default("USDC")
  label       String?
  memo        String?
  senderName  String?

  // Invoice-specific (optional, ignored for type=link)
  lineItems       Json?
  dueDate         DateTime?
  recipientName   String?
  recipientEmail  String?
  sentAt          DateTime?
  reminderSentAt  DateTime?

  // Payment tracking
  paymentMethod   String?
  paidAt          DateTime?
  paidBy          String?
  txDigest        String?    @unique
  expiresAt       DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([suiAddress])
  @@index([status])
  @@index([dueDate, status])
}

model WatchAddress {
  id        String   @id @default(cuid())
  userId    String
  address   String
  label     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, address])
  @@index([userId])
}

model PortfolioSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date

  walletValueUsd  Float
  savingsValueUsd Float
  debtValueUsd    Float
  netWorthUsd     Float
  yieldEarnedUsd  Float
  healthFactor    Float?
  allocations     Json

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model UserFinancialProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  riskAppetite         String   @default("moderate")  // conservative | moderate | aggressive
  financialLiteracy    String   @default("intermediate") // novice | intermediate | advanced
  prefersBriefResponses Boolean @default(false)
  prefersExplainers    Boolean @default(true)
  currencyFraming      String  @default("usdc") // usdc | fiat
  primaryGoals         String[] @default([])
  knownPatterns        String[] @default([])
  riskConfidence       Float   @default(0)
  literacyConfidence   Float   @default(0)
  inferenceVersion     Int     @default(1)
  lastInferredAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserMemory {
  id              String    @id @default(cuid())
  userId          String
  memoryType      String    // preference | fact | pattern | goal | concern
  content         String
  originalQuote   String?
  confidence      Float     @default(0.8)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  sourceSessionId String?
  source          String    @default("conversation") // 'conversation' | 'chain'
  extractedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, active])
  @@index([expiresAt])
}

model LinkedWallet {
  id         String    @id @default(cuid())
  userId     String
  suiAddress String
  label      String?
  isPrimary  Boolean   @default(false)
  verifiedAt DateTime?
  addedAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, suiAddress])
  @@index([userId])
}

/// [v1.4] HarnessMetrics — per-turn instrumentation row written by the
/// chat route at turn close. Purely additive, fire-and-forget; failures
/// must never block a chat response. Retention is 90 days via Vercel cron.
model TurnMetrics {
  id                   String   @id @default(cuid())
  sessionId            String
  userId               String
  turnIndex            Int
  effortLevel          String
  modelUsed            String
  wallTimeMs           Int
  firstTokenMs         Int
  toolsCalled          Json
  guardsFired          Json
  compactionTriggered  Boolean  @default(false)
  contextTokensStart   Int
  cacheHit             Boolean  @default(false)
  cacheReadTokens      Int      @default(0)
  cacheWriteTokens     Int      @default(0)
  inputTokens          Int
  outputTokens         Int
  estimatedCostUsd     Float
  pendingActionYielded Boolean  @default(false)
  pendingActionOutcome String?
  aciRefinements       Int      @default(0)
  sessionSpendUsd      Float    @default(0)
  /// [v1.5.1] Drift signal for the `cacheable: false` invariant.
  /// Counts tools in `MUTABLE_TOOL_SET` (derived from the post-write
  /// refresh map) whose `resultDeduped` flag flipped true this turn.
  /// Microcompact MUST never dedupe these tools; if this column is ever
  /// > 0 in prod, a new mutable tool was added to the refresh map but
  /// the engine's `Tool.cacheable: false` annotation was forgotten.
  /// Cheap audit: `SELECT id, modelUsed, mutableToolDedupes FROM
  /// "TurnMetrics" WHERE "mutableToolDedupes" > 0;`
  mutableToolDedupes   Int      @default(0)
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([effortLevel, modelUsed])
  @@index([createdAt])
}
