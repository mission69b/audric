generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  suiAddress       String    @unique
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  emailVerifyToken String?
  emailVerifyExpiry DateTime?
  displayName      String?
  timezoneOffset   Int       @default(0)
  onboardedAt      DateTime?
  tosAcceptedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  preferences          UserPreferences?
  conversationLogs     ConversationLog[]
  notificationPrefs    NotificationPrefs[]
  dailyBriefings       DailyBriefing[]
  savingsGoals         SavingsGoal[]
  adviceLogs           AdviceLog[]
  savingsGoalDeposits  SavingsGoalDeposit[]
  payments             Payment[]
  watchAddresses       WatchAddress[]
  portfolioSnapshots   PortfolioSnapshot[]
  scheduledActions     ScheduledAction[]
  outcomeChecks        OutcomeCheck[]
  followUpQueue        FollowUpQueue[]
  financialProfile     UserFinancialProfile?
  memories             UserMemory[]
  linkedWallets        LinkedWallet[]

  @@index([email])
  @@index([emailVerified, timezoneOffset])
}

model UserPreferences {
  address      String   @id
  allowanceId  String?
  contacts     Json     @default("[]")
  limits       Json?
  dcaSchedules Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

model ConversationLog {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  role       String
  content    String
  toolCalls  Json?
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId])
}

model SessionUsage {
  id               String   @id @default(cuid())
  address          String
  sessionId        String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costUsd          Float    @default(0)
  toolNames        String[] @default([])
  model            String?
  createdAt        DateTime @default(now())

  @@index([address, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model ServicePurchase {
  id        String   @id @default(cuid())
  address   String
  serviceId String
  amountUsd Float
  productId String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  @@index([address, createdAt])
}

model NotificationPrefs {
  userId     String
  feature    String
  enabled    Boolean   @default(true)
  lastSentAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@id([userId, feature])
  @@index([userId])
}

model NotificationLog {
  id         String   @id @default(cuid())
  job        String
  processed  Int
  sent       Int
  errors     Int
  reportedAt DateTime
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model DailyBriefing {
  id           String    @id @default(cuid())
  userId       String
  date         String
  content      Json
  emailSentAt  DateTime?
  dismissedAt  DateTime?
  chargeDigest String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, dismissedAt])
}

model SavingsGoal {
  id               String    @id @default(cuid())
  userId           String
  name             String
  emoji            String    @default("🎯")
  targetAmount     Float
  deadline         DateTime?
  currentMilestone Int       @default(0)
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  adviceLogs AdviceLog[]
  deposits   SavingsGoalDeposit[]

  @@index([userId, status])
}

model AppEvent {
  id             String   @id @default(cuid())
  address        String
  type           String
  title          String
  details        Json?
  digest         String?
  adviceLogId    String?
  goalId         String?
  suiTxVerified  Boolean  @default(false)
  source         String   @default("chat")
  createdAt      DateTime @default(now())

  @@index([address, createdAt])
  @@index([address, type, createdAt])
  @@index([adviceLogId])
  @@index([goalId])
}

model AdviceLog {
  id            String       @id @default(cuid())
  userId        String
  sessionId     String
  adviceText    String
  adviceType    String
  targetAmount  Float?
  goalId        String?
  actionTaken   Boolean      @default(false)
  appEventId    String?
  followUpDue   DateTime?
  followUpSent  Boolean      @default(false)
  outcomeStatus String       @default("pending")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user           User           @relation(fields: [userId], references: [id])
  goal           SavingsGoal?   @relation(fields: [goalId], references: [id])
  outcomeChecks  OutcomeCheck[]

  @@index([userId])
  @@index([outcomeStatus])
  @@index([followUpDue])
  @@index([createdAt])
}

model Payment {
  id          String    @id @default(cuid())
  slug        String    @unique
  nonce       String    @default(uuid())
  userId      String
  suiAddress  String

  type        String    @default("link")
  status      String    @default("active")
  amount      Float?
  currency    String    @default("USDC")
  label       String?
  memo        String?
  senderName  String?

  // Invoice-specific (optional, ignored for type=link)
  lineItems       Json?
  dueDate         DateTime?
  recipientName   String?
  recipientEmail  String?
  sentAt          DateTime?
  reminderSentAt  DateTime?

  // Payment tracking
  paymentMethod   String?
  paidAt          DateTime?
  paidBy          String?
  txDigest        String?    @unique
  expiresAt       DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([suiAddress])
  @@index([status])
  @@index([dueDate, status])
}

model SavingsGoalDeposit {
  id         String   @id @default(cuid())
  goalId     String
  userId     String
  amountUsdc Float
  appEventId String?
  createdAt  DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id])
  user User        @relation(fields: [userId], references: [id])

  @@index([goalId])
  @@index([userId])
}

model WatchAddress {
  id        String   @id @default(cuid())
  userId    String
  address   String
  label     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, address])
  @@index([userId])
}

model PortfolioSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date

  walletValueUsd  Float
  savingsValueUsd Float
  debtValueUsd    Float
  netWorthUsd     Float
  yieldEarnedUsd  Float
  healthFactor    Float?
  allocations     Json

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model ScheduledAction {
  id                     String    @id @default(cuid())
  userId                 String
  actionType             String    // save | swap | repay
  amount                 Float
  asset                  String    @default("USDC")
  targetAsset            String?
  cronExpr               String    // e.g. "0 9 * * 5" (Fridays 9am)
  nextRunAt              DateTime
  enabled                Boolean   @default(true)
  confirmationsRequired  Int       @default(5)
  confirmationsCompleted Int       @default(0)
  totalExecutions        Int       @default(0)
  totalAmountUsdc        Float     @default(0)
  lastExecutedAt         DateTime?
  lastSkippedAt          DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Phase D: autonomous action loop
  source      String    @default("user_created") // user_created | behavior_detected
  patternType String?   // recurring_save | yield_reinvestment | debt_discipline | idle_usdc_tolerance | swap_pattern
  detectedAt  DateTime?
  confidence  Float?
  stage       Int       @default(2) // 0=detected, 1=surfaced, 2=confirmed, 3=autonomous
  declinedAt  DateTime?
  pausedAt    DateTime?

  user       User                 @relation(fields: [userId], references: [id])
  executions ScheduledExecution[]

  @@index([userId, enabled])
  @@index([nextRunAt, enabled])
  @@index([userId, source, stage])
}

model ScheduledExecution {
  id                String   @id @default(cuid())
  scheduledActionId String
  txDigest          String?
  amountUsd         Float
  status            String   // success | skipped | failed
  skipReason        String?
  idempotencyKey    String   @unique
  notified          Boolean  @default(false)
  executedAt        DateTime @default(now())

  scheduledAction ScheduledAction @relation(fields: [scheduledActionId], references: [id])

  @@index([scheduledActionId, executedAt])
}

model OutcomeCheck {
  id            String   @id @default(cuid())
  userId        String
  adviceLogId   String
  checkType     String   // savings_delta | goal_progress | debt_change | rate_change
  expectedValue Float?
  actualValue   Float?
  deltaUsdc     Float?
  onTrack       Boolean?
  suiQueryAt    DateTime
  createdAt     DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  adviceLog AdviceLog @relation(fields: [adviceLogId], references: [id])

  @@index([userId])
  @@index([adviceLogId])
}

model FollowUpQueue {
  id              String    @id @default(cuid())
  userId          String
  triggerType     String    // scheduled | anomaly | goal_milestone | off_track
  adviceLogId     String?
  outcomeCheckId  String?
  message         String
  ctaType         String?
  ctaAmount       Float?
  priority        String    @default("normal") // urgent | normal | low
  scheduledFor    DateTime
  sentAt          DateTime?
  deliveryMethod  String    @default("in_app") // in_app | email | both
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, sentAt])
  @@index([scheduledFor, sentAt])
  @@index([triggerType])
}

model UserFinancialProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  riskAppetite         String   @default("moderate")  // conservative | moderate | aggressive
  financialLiteracy    String   @default("intermediate") // novice | intermediate | advanced
  prefersBriefResponses Boolean @default(false)
  prefersExplainers    Boolean @default(true)
  currencyFraming      String  @default("usdc") // usdc | fiat
  primaryGoals         String[] @default([])
  knownPatterns        String[] @default([])
  riskConfidence       Float   @default(0)
  literacyConfidence   Float   @default(0)
  inferenceVersion     Int     @default(1)
  lastInferredAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserMemory {
  id              String    @id @default(cuid())
  userId          String
  memoryType      String    // preference | fact | pattern | goal | concern
  content         String
  originalQuote   String?
  confidence      Float     @default(0.8)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  sourceSessionId String?
  source          String    @default("conversation") // 'conversation' | 'chain'
  extractedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, active])
  @@index([expiresAt])
}

model LinkedWallet {
  id         String    @id @default(cuid())
  userId     String
  suiAddress String
  label      String?
  isPrimary  Boolean   @default(false)
  verifiedAt DateTime?
  addedAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, suiAddress])
  @@index([userId])
}

model PublicReport {
  id          String   @id @default(cuid())
  suiAddress  String
  reportData  Json
  viewCount   Int      @default(0)
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@index([suiAddress, generatedAt])
}
