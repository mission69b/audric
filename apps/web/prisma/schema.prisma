generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  suiAddress       String    @unique
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  emailVerifyToken String?
  emailVerifyExpiry DateTime?
  displayName      String?
  timezoneOffset   Int       @default(0)
  onboardedAt      DateTime?
  tosAcceptedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  preferences          UserPreferences?
  conversationLogs     ConversationLog[]
  notificationPrefs    NotificationPrefs[]
  dailyBriefings       DailyBriefing[]
  savingsGoals         SavingsGoal[]
  adviceLogs           AdviceLog[]
  savingsGoalDeposits  SavingsGoalDeposit[]
  paymentLinks         PaymentLink[]
  invoices             Invoice[]
  watchAddresses       WatchAddress[]
  portfolioSnapshots   PortfolioSnapshot[]

  @@index([email])
  @@index([emailVerified, timezoneOffset])
}

model UserPreferences {
  address      String   @id
  contacts     Json     @default("[]")
  limits       Json?
  dcaSchedules Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

model ConversationLog {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  role       String
  content    String
  toolCalls  Json?
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId])
}

model SessionUsage {
  id               String   @id @default(cuid())
  address          String
  sessionId        String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costUsd          Float    @default(0)
  toolNames        String[] @default([])
  model            String?
  createdAt        DateTime @default(now())

  @@index([address, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model ServicePurchase {
  id        String   @id @default(cuid())
  address   String
  serviceId String
  amountUsd Float
  productId String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  @@index([address, createdAt])
}

model NotificationPrefs {
  userId     String
  feature    String
  enabled    Boolean   @default(true)
  lastSentAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@id([userId, feature])
  @@index([userId])
}

model NotificationLog {
  id         String   @id @default(cuid())
  job        String
  processed  Int
  sent       Int
  errors     Int
  reportedAt DateTime
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model DailyBriefing {
  id           String    @id @default(cuid())
  userId       String
  date         String
  content      Json
  emailSentAt  DateTime?
  dismissedAt  DateTime?
  chargeDigest String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, dismissedAt])
}

model SavingsGoal {
  id               String    @id @default(cuid())
  userId           String
  name             String
  emoji            String    @default("🎯")
  targetAmount     Float
  deadline         DateTime?
  currentMilestone Int       @default(0)
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  adviceLogs AdviceLog[]
  deposits   SavingsGoalDeposit[]

  @@index([userId, status])
}

model AppEvent {
  id             String   @id @default(cuid())
  address        String
  type           String
  title          String
  details        Json?
  digest         String?
  adviceLogId    String?
  goalId         String?
  suiTxVerified  Boolean  @default(false)
  source         String   @default("chat")
  createdAt      DateTime @default(now())

  @@index([address, createdAt])
  @@index([address, type, createdAt])
  @@index([adviceLogId])
  @@index([goalId])
}

model AdviceLog {
  id            String       @id @default(cuid())
  userId        String
  sessionId     String
  adviceText    String
  adviceType    String
  targetAmount  Float?
  goalId        String?
  actionTaken   Boolean      @default(false)
  appEventId    String?
  followUpDue   DateTime?
  followUpSent  Boolean      @default(false)
  outcomeStatus String       @default("pending")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user User         @relation(fields: [userId], references: [id])
  goal SavingsGoal? @relation(fields: [goalId], references: [id])

  @@index([userId])
  @@index([outcomeStatus])
  @@index([followUpDue])
  @@index([createdAt])
}

model PaymentLink {
  id          String    @id @default(cuid())
  slug        String    @unique
  userId      String
  suiAddress  String
  amount      Float?
  label       String?
  memo        String?
  currency    String    @default("USDC")
  status      String    @default("active")
  expiresAt   DateTime?
  paidAt      DateTime?
  paidBy      String?
  txDigest    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([suiAddress])
}

model Invoice {
  id              String    @id @default(cuid())
  slug            String    @unique
  userId          String
  suiAddress      String
  recipientEmail  String?
  recipientName   String?
  amount          Float
  currency        String    @default("USDC")
  label           String
  items           Json      @default("[]")
  memo            String?
  dueDate         DateTime?
  status          String    @default("pending")
  paidAt          DateTime?
  paidBy          String?
  txDigest        String?
  sentAt          DateTime?
  reminderSentAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([dueDate, status])
}

model SavingsGoalDeposit {
  id         String   @id @default(cuid())
  goalId     String
  userId     String
  amountUsdc Float
  appEventId String?
  createdAt  DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id])
  user User        @relation(fields: [userId], references: [id])

  @@index([goalId])
  @@index([userId])
}

model WatchAddress {
  id        String   @id @default(cuid())
  userId    String
  address   String
  label     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, address])
  @@index([userId])
}

model PortfolioSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date

  walletValueUsd  Float
  savingsValueUsd Float
  debtValueUsd    Float
  netWorthUsd     Float
  yieldEarnedUsd  Float
  healthFactor    Float?
  allocations     Json

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}
