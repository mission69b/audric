generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @default(cuid())
  suiAddress       String    @unique
  email            String?   @unique
  emailVerified    Boolean   @default(false)
  displayName      String?
  timezoneOffset   Int       @default(0)
  tosAcceptedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  preferences          UserPreferences?
  conversationLogs     ConversationLog[]
  savingsGoals         SavingsGoal[]
  adviceLogs           AdviceLog[]
  payments             Payment[]
  watchAddresses       WatchAddress[]
  portfolioSnapshots   PortfolioSnapshot[]
  financialProfile     UserFinancialProfile?
  memories             UserMemory[]
  linkedWallets        LinkedWallet[]

  @@index([email])
  @@index([emailVerified, timezoneOffset])
}

model UserPreferences {
  address      String   @id
  contacts     Json     @default("[]")
  limits       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

model ConversationLog {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  role       String
  content    String
  toolCalls  Json?
  tokensUsed Int      @default(0)
  costUsd    Float    @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId])
}

model SessionUsage {
  id               String   @id @default(cuid())
  address          String
  sessionId        String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costUsd          Float    @default(0)
  toolNames        String[] @default([])
  model            String?
  createdAt        DateTime @default(now())

  @@index([address, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model ServicePurchase {
  id        String   @id @default(cuid())
  address   String
  serviceId String
  amountUsd Float
  productId String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  @@index([address, createdAt])
}

model SavingsGoal {
  id               String    @id @default(cuid())
  userId           String
  name             String
  emoji            String    @default("🎯")
  targetAmount     Float
  deadline         DateTime?
  status           String    @default("active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  adviceLogs AdviceLog[]

  @@index([userId, status])
}

model AppEvent {
  id             String   @id @default(cuid())
  address        String
  type           String
  title          String
  details        Json?
  digest         String?
  adviceLogId    String?
  goalId         String?
  suiTxVerified  Boolean  @default(false)
  source         String   @default("chat")
  createdAt      DateTime @default(now())

  @@index([address, createdAt])
  @@index([address, type, createdAt])
  @@index([adviceLogId])
  @@index([goalId])
}

model AdviceLog {
  id            String       @id @default(cuid())
  userId        String
  sessionId     String
  adviceText    String
  adviceType    String
  targetAmount  Float?
  goalId        String?
  appEventId    String?
  /// [v1.4.2 — Day 3 / Spec §AdviceLog migration] Set to `true` when the
  /// user acts on the suggestion (e.g. confirms a recommended save / swap
  /// originated from the surfaced advice). Used by the daily financial-
  /// context cron to surface only *unactioned* advice as
  /// `pendingAdvice` — without this flag the cron re-surfaces stale
  /// suggestions the user already followed. Default `false` covers all
  /// pre-migration rows correctly (treat as not yet acted on).
  actedOn       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user           User           @relation(fields: [userId], references: [id])
  goal           SavingsGoal?   @relation(fields: [goalId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Payment {
  id          String    @id @default(cuid())
  slug        String    @unique
  nonce       String    @default(uuid())
  userId      String
  suiAddress  String

  type        String    @default("link")
  status      String    @default("active")
  amount      Float?
  currency    String    @default("USDC")
  label       String?
  memo        String?
  senderName  String?

  // Invoice-specific (optional, ignored for type=link)
  lineItems       Json?
  dueDate         DateTime?
  recipientName   String?
  recipientEmail  String?
  sentAt          DateTime?
  reminderSentAt  DateTime?

  // Payment tracking
  paymentMethod   String?
  paidAt          DateTime?
  paidBy          String?
  txDigest        String?    @unique
  expiresAt       DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([suiAddress])
  @@index([status])
  @@index([dueDate, status])
}

model WatchAddress {
  id        String   @id @default(cuid())
  userId    String
  address   String
  label     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, address])
  @@index([userId])
}

model PortfolioSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date

  walletValueUsd  Float
  savingsValueUsd Float
  debtValueUsd    Float
  netWorthUsd     Float
  yieldEarnedUsd  Float
  healthFactor    Float?
  // Weighted average APY across all savings positions, expressed as a
  // decimal (e.g. 0.0421 = 4.21%). Persisted so the daily
  // financial-context-snapshot cron can wire `currentApy` into the
  // <financial_context> agent prompt block without re-fetching positions
  // per user. Nullable for backfill compatibility on rows written before
  // this column existed.
  savingsRate     Float?
  allocations     Json

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

model UserFinancialProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  riskAppetite         String   @default("moderate")  // conservative | moderate | aggressive
  financialLiteracy    String   @default("intermediate") // novice | intermediate | advanced
  prefersBriefResponses Boolean @default(false)
  prefersExplainers    Boolean @default(true)
  currencyFraming      String  @default("usdc") // usdc | fiat
  primaryGoals         String[] @default([])
  knownPatterns        String[] @default([])
  riskConfidence       Float   @default(0)
  literacyConfidence   Float   @default(0)
  inferenceVersion     Int     @default(1)
  lastInferredAt       DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserMemory {
  id              String    @id @default(cuid())
  userId          String
  memoryType      String    // preference | fact | pattern | goal | concern
  content         String
  originalQuote   String?
  confidence      Float     @default(0.8)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  sourceSessionId String?
  source          String    @default("conversation") // 'conversation' | 'chain'
  extractedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, active])
  @@index([expiresAt])
}

model LinkedWallet {
  id         String    @id @default(cuid())
  userId     String
  suiAddress String
  label      String?
  isPrimary  Boolean   @default(false)
  verifiedAt DateTime?
  addedAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, suiAddress])
  @@index([userId])
}

/// [v1.4] HarnessMetrics — per-turn instrumentation row written by the
/// chat route at turn close. Purely additive, fire-and-forget; failures
/// must never block a chat response. Retention is 90 days via Vercel cron.
model TurnMetrics {
  id                   String   @id @default(cuid())
  sessionId            String
  userId               String
  turnIndex            Int
  effortLevel          String
  modelUsed            String
  wallTimeMs           Int
  firstTokenMs         Int
  toolsCalled          Json
  guardsFired          Json
  compactionTriggered  Boolean  @default(false)
  contextTokensStart   Int
  cacheHit             Boolean  @default(false)
  cacheReadTokens      Int      @default(0)
  cacheWriteTokens     Int      @default(0)
  inputTokens          Int
  outputTokens         Int
  estimatedCostUsd     Float
  pendingActionYielded Boolean  @default(false)
  pendingActionOutcome String?
  aciRefinements       Int      @default(0)
  sessionSpendUsd      Float    @default(0)
  /// [v1.5.1] Drift signal for the `cacheable: false` invariant.
  /// Counts tools in `MUTABLE_TOOL_SET` (derived from the post-write
  /// refresh map) whose `resultDeduped` flag flipped true this turn.
  /// Microcompact MUST never dedupe these tools; if this column is ever
  /// > 0 in prod, a new mutable tool was added to the refresh map but
  /// the engine's `Tool.cacheable: false` annotation was forgotten.
  /// Cheap audit: `SELECT id, modelUsed, mutableToolDedupes FROM
  /// "TurnMetrics" WHERE "mutableToolDedupes" > 0;`
  mutableToolDedupes   Int      @default(0)
  /// [v1.4.2 — Day 3 / Spec Item 3] Per-yield UUID emitted by the engine
  /// on `pending_action`. Nullable because (a) turns without a write
  /// never yield one and (b) pre-migration rows have no value. The
  /// resume route's `prisma.turnMetrics.updateMany` keys on this column
  /// instead of `(sessionId, turnIndex)` to eliminate the cross-attempt
  /// false-resolution that pair allows when the same turn yields a
  /// second pending action (e.g. modifiable-field re-yield). Indexed
  /// because resume is a per-row lookup and the column is sparse.
  attemptId            String?
  /// [v1.4.2 — Day 3] `true` when this turn was driven by a
  /// pre-fetch / synthetic intent (e.g. resumed-session snapshot reads)
  /// rather than a user prompt. Lets dashboards exclude synthetic
  /// turns from latency / cost percentiles without losing the
  /// instrumentation row.
  synthetic            Boolean  @default(false)
  /// [v1.4.2 — Day 3] Wall-clock ms reported by the host for the
  /// client-side write tool execution (signing + broadcast +
  /// indexer-lag absorption). Written only on resume; null on the
  /// initial chat row that yielded the `pending_action`.
  writeToolDurationMs  Int?
  /// [v1.4.2 — Day 3] Estimated USD savings from prompt-cache reads on
  /// this turn — `cacheReadTokens * (input_rate - cacheRead_rate)` per
  /// `costRatesForModel`. Reported separately from `estimatedCostUsd`
  /// so dashboards can attribute hit-rate value without subtraction.
  cacheSavingsUsd      Float    @default(0)
  /// [v1.4.2 — Day 3] Phase of the turn that produced this row:
  /// `'initial'` for the chat-route close, `'resume'` for the row the
  /// resume-route close writes when the user resolves the pending
  /// action. Default `'initial'` is the safe value for backfilled
  /// pre-migration rows (none of them carried a resume row).
  turnPhase            String   @default("initial")
  /// [SPEC 8 v0.5.1 B3.6 / Layer 6] One-shot per-turn shape declared by
  /// the engine `harness_shape` event: `'lean' | 'standard' | 'rich' |
  /// 'max'`. Null on rows that pre-date the engine event (engines
  /// older than v1.5.0). Drives the dashboard segmentation that
  /// catches LEAN-turn regressions (any non-zero `todoUpdateCount`
  /// or `thinkingBlockCount > 0` on a `harnessShape='lean'` row is a
  /// shape-contract violation worth investigating).
  harnessShape         String?
  /// [SPEC 8 v0.5.1 B3.6] Count of `thinking_done` events emitted this
  /// turn. Soft-capped per shape (lean=0, standard=3, rich=5, max=8).
  thinkingBlockCount   Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6] Count of `update_todo` tool calls this turn
  /// (one increment per `todo_update` engine event). Forbidden on
  /// `lean` shape; non-zero on `lean` rows is a regression signal.
  todoUpdateCount      Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6] Time To First Visible Progress — ms from
  /// turn start to the first host-renderable event (`thinking_delta`,
  /// `tool_start`, `todo_update`, or `text_delta`, whichever first).
  /// Null when the turn produced no renderable events (rare error
  /// path). p50 ≤ 1500ms is the SPEC 8 v0.5.1 B3.7 rollout gate.
  ttfvpMs              Int?
  /// [SPEC 8 v0.5.1 B3.6] Output tokens for `text_delta` events only
  /// (excludes thinking + tool I/O). Approximated as
  /// `Math.ceil(charCount / 4)` to match `@t2000/engine` `estimateTokens`.
  /// Canonical terseness signal — p50 ≤ baseline + 50% is the
  /// final-text-discipline rollout gate.
  finalTextTokens      Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / G9] Raw count of `<eval_summary>` markers
  /// parsed by the engine (`thinking_done.summaryMode === true`).
  /// No quality judgment — dashboard derives the appropriately-emitted
  /// rate from `WHERE harnessShape >= 'standard'`. Should be 0 on lean.
  evalSummaryEmittedCount Int   @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / G9] Increments when `evalSummaryEmittedCount
  /// > 1` in the same turn (multiple markers — broken trust-card UX).
  /// Should be ~zero in steady state.
  evalSummaryViolationsCount Int @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / D2] True when a `pending_input` event arrived
  /// on a session pinned to the legacy harness. Should ALWAYS be false
  /// in production under engine v1.5.0 (which doesn't emit
  /// `pending_input`); non-zero means session pinning broke or a SPEC
  /// 9 v0.1.2 emission leaked into a legacy session.
  pendingInputSeenOnLegacy Boolean @default(false)
  /// [SPEC 8 v0.5.1 B3.6] Count of `tool_progress` events emitted by
  /// long-running tools this turn. Spec target: ≥80% of swap_execute
  /// turns emit at least one progress event once the wiring lands.
  toolProgressEventCount Int   @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / Gap J] 1 when the turn ended without
  /// `turn_complete` AND without `pending_action` (interrupted —
  /// client abort, serverless timeout, network drop). Rollback gate:
  /// >1% over 24h triggers SPEC 8 v0.5.1 B3.7 flag rollback.
  interruptedMessageCount Int  @default(0)
  createdAt            DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([effortLevel, modelUsed])
  @@index([createdAt])
  @@index([attemptId])
  @@index([harnessShape])
}

/// [v1.4.2 — Day 5 / Spec Item 6] Daily snapshot of every active user's
/// orientation block — savings / debt / wallet totals, health factor, open
/// goals, last unactioned advice, and a one-line "recent activity"
/// summary. Read by `engine-context.ts:buildDynamicBlock` at engine boot
/// to seed the `<financial_context>` system-prompt section so a returning
/// user gets a contextual greeting WITHOUT spending tool calls (and tokens)
/// re-deriving state every session.
///
/// Dual-key by design [v1.4 — B2]: callers in the engine path only know
/// the wallet `address` (no Prisma `User.id` cuid), but joins to
/// `AdviceLog` / `SavingsGoal` / `PortfolioSnapshot` need the cuid. The
/// cron writer populates BOTH on upsert so either lookup works.
///
/// Cached at `fin_ctx:${address}` in Upstash Redis with a 24h TTL that
/// matches the cron cadence. Invalidated synchronously after every
/// auto-tier (`engine-factory.ts:onAutoExecuted`) and confirm-tier
/// (`resume/route.ts`) write so a user who saves / sends / swaps and
/// reopens chat 5 minutes later sees the updated snapshot — not a
/// stale 23-hour-old block. Reading is fail-open: a Redis miss falls
/// through to Prisma, and a Prisma miss returns `null` (the engine
/// boot path then skips the `<financial_context>` section entirely).
model UserFinancialContext {
  id                   String   @id @default(cuid())
  userId               String   @unique
  address              String   @unique
  savingsUsdc          Float
  debtUsdc             Float
  healthFactor         Float?
  walletUsdc           Float
  /// [Bug 1c / 2026-04-27] USDsui breakouts. NAVI's USDsui pool launched
  /// after this table was created, so both columns are nullable for
  /// backfill (older rows return `null`, which the prompt builder treats
  /// as "no USDsui line"). Both values are USD-equivalent (USDsui is
  /// $1-pegged) and live alongside the existing USDC fields rather than
  /// replacing them — pre-fix the LLM was answering balance questions
  /// from a USDC-labeled aggregate that silently dropped USDsui.
  walletUsdsui         Float?
  savingsUsdsui        Float?
  currentApy           Float?
  recentActivity       String
  openGoals            Json
  pendingAdvice        String?
  daysSinceLastSession Int
  generatedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
