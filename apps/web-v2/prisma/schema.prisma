generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  suiAddress  String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // SPEC 10 (Audric Passport Identity) — 4 fields shipped in migration
  // 20260505200000_spec10_add_username_to_user. `username` is the bare
  // label (e.g. "alice"); the full handle is computed via `fullHandle()`
  // from @t2000/sdk to give "alice.audric.sui". Unique on the DB side
  // (PostgreSQL allows multiple NULLs, which is exactly what we want for
  // unclaimed users); also unique on the SuiNS chain side (only one
  // address can claim a given leaf under audric.sui). The DB unique
  // index lets /api/identity/check fail-fast before hitting the chain.
  // `usernameMintTxDigest` is the on-chain proof of the leaf creation
  // tx — useful for support / audit / "show me when I claimed it" UX.
  username              String?   @unique
  usernameClaimedAt     DateTime?
  usernameLastChangedAt DateTime?
  usernameMintTxDigest  String?

  // [S.261 — 2026-05-23] Dropped: `email`, `emailVerified`, `timezoneOffset`,
  // `tosAcceptedAt` + their two indexes. Email/emailVerified now derive
  // from the zkLogin JWT at request time (`isJwtEmailVerified`,
  // `decodeJwtClaim`); the DB columns were never authoritative post-
  // Resend-verify removal. `timezoneOffset` was DOA — never written or
  // read. `tosAcceptedAt` had a write route + status flag but its UI
  // consumer (the TOS modal) was retired; the flag was fetched and
  // ignored. See migration `20260523000000_s261_drop_dead_user_columns/
  // migration.sql`.

  preferences        UserPreferences?
  adviceLogs         AdviceLog[]
  payments           Payment[]
  portfolioSnapshots PortfolioSnapshot[]
  // v0.7e Persistent Chats (S.247) — back-relation; Chat FKs to `suiAddress`
  // (canonical user identity post-zkLogin) rather than `id` (cuid).
  chats              Chat[]
}

model UserPreferences {
  address   String   @id
  limits    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}

// [v0.7e Phase 5 cleanup / S.254 — 2026-05-22] ConversationLog model +
// table dropped. Zero writers anywhere; the only consumer was the
// retention cron (DELETE-only). Superseded by AI SDK's native message
// persistence (Chat + Message models in S.247) which already captures
// everything we need. Migration `20260522120000_v07e_drop_dead_tables_
// and_columns/migration.sql` drops the matching Postgres table.

model SessionUsage {
  id               String   @id @default(cuid())
  address          String
  sessionId        String
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  costUsd          Float    @default(0)
  toolNames        String[] @default([])
  model            String?
  createdAt        DateTime @default(now())

  @@index([address, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model ServicePurchase {
  id        String   @id @default(cuid())
  address   String
  serviceId String
  amountUsd Float
  productId String?
  status    String   @default("completed")
  createdAt DateTime @default(now())

  @@index([address, createdAt])
}

model AppEvent {
  id            String   @id @default(cuid())
  address       String
  type          String
  title         String
  details       Json?
  digest        String?
  adviceLogId   String?
  suiTxVerified Boolean  @default(false)
  source        String   @default("chat")
  createdAt     DateTime @default(now())

  @@index([address, createdAt])
  @@index([address, type, createdAt])
  @@index([adviceLogId])
}

model AdviceLog {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String
  adviceText   String
  adviceType   String
  targetAmount Float?
  appEventId   String?
  /// [v1.4.2 — Day 3 / Spec §AdviceLog migration] Set to `true` when the
  /// user acts on the suggestion (e.g. confirms a recommended save / swap
  /// originated from the surfaced advice). Used by the daily financial-
  /// context cron to surface only *unactioned* advice as
  /// `pendingAdvice` — without this flag the cron re-surfaces stale
  /// suggestions the user already followed. Default `false` covers all
  /// pre-migration rows correctly (treat as not yet acted on).
  actedOn      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// [V07E_INVOICE_DEPRECATION / S.269 item 7 — 2026-05-23] Phase 5 dropped
// the 6 invoice-only columns (lineItems, dueDate, recipientName,
// recipientEmail, sentAt, reminderSentAt) and the dueDate-status
// composite index. Founder Q2 = C: invoice rows deleted directly (no
// archive); 50 rows total — only 3 actually paid for $7.99 across small
// test transactions, $1.02M of "active" invoices was a test row with a
// huge amount entered. The `type` field stays at default "link" with a
// CHECK constraint enforcing the only legal value, so the next line of
// defense against a typo'd insert is the DB itself.
model Payment {
  id         String @id @default(cuid())
  slug       String @unique
  nonce      String @default(uuid())
  userId     String
  suiAddress String

  type       String  @default("link")
  status     String  @default("active")
  amount     Float?
  currency   String  @default("USDC")
  label      String?
  memo       String?
  senderName String?

  // Payment tracking
  paymentMethod String?
  paidAt        DateTime?
  paidBy        String?
  txDigest      String?   @unique
  expiresAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([suiAddress])
  @@index([status])
}

// [v0.7e Phase 5 cleanup / S.254 — 2026-05-22] WatchAddress model +
// table dropped. Zero call sites; multi-wallet watch-only addresses
// feature retired silently in early 2026. Migration `20260522120000_
// v07e_drop_dead_tables_and_columns/migration.sql` drops the matching
// Postgres table.

model PortfolioSnapshot {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date

  walletValueUsd  Float
  savingsValueUsd Float
  debtValueUsd    Float
  netWorthUsd     Float
  yieldEarnedUsd  Float
  healthFactor    Float?
  // Weighted average APY across all savings positions, expressed as a
  // decimal (e.g. 0.0421 = 4.21%). Originally persisted to feed the daily
  // financial-context-snapshot cron (retired S.375); now retained as part
  // of the historical PortfolioSnapshot timeline row. Nullable for backfill
  // compatibility on rows written before this column existed.
  savingsRate     Float?
  allocations     Json

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
}

// [v0.7d Phase 6 Block A — 2026-05-21 / S.221] UserFinancialProfile +
// UserMemory models deleted alongside their feeder crons (profile-
// inference, memory-extraction, chain-memory) and their consumer
// routes. MemWal `<memory_recall>` (web-v2 `prepareStep`) is now the
// canonical cross-session memory surface. Migration `20260521000000_
// drop_user_memory_and_user_financial_profile/migration.sql` drops the
// matching Postgres tables.

// [v0.7e Phase 5 cleanup / S.254 — 2026-05-22] LinkedWallet model +
// table dropped. Zero call sites; current zkLogin flow is single-
// wallet-per-Google-account by construction. Migration `20260522120000_
// v07e_drop_dead_tables_and_columns/migration.sql` drops the matching
// Postgres table.

/// [v1.4] HarnessMetrics — per-turn instrumentation row written by the
/// chat route at turn close. Purely additive, fire-and-forget; failures
/// must never block a chat response. Retention is 90 days via Vercel cron.
model TurnMetrics {
  id                         String   @id @default(cuid())
  sessionId                  String
  userId                     String
  turnIndex                  Int
  effortLevel                String
  modelUsed                  String
  wallTimeMs                 Int
  firstTokenMs               Int
  toolsCalled                Json
  guardsFired                Json
  compactionTriggered        Boolean  @default(false)
  contextTokensStart         Int
  cacheHit                   Boolean  @default(false)
  cacheReadTokens            Int      @default(0)
  cacheWriteTokens           Int      @default(0)
  inputTokens                Int
  outputTokens               Int
  estimatedCostUsd           Float
  pendingActionYielded       Boolean  @default(false)
  pendingActionOutcome       String?
  aciRefinements             Int      @default(0)
  sessionSpendUsd            Float    @default(0)
  /// [v1.5.1] Drift signal for the `cacheable: false` invariant.
  /// Counts tools in `MUTABLE_TOOL_SET` (derived from the post-write
  /// refresh map) whose `resultDeduped` flag flipped true this turn.
  /// Microcompact MUST never dedupe these tools; if this column is ever
  /// > 0 in prod, a new mutable tool was added to the refresh map but
  /// the engine's `Tool.cacheable: false` annotation was forgotten.
  /// Cheap audit: `SELECT id, modelUsed, mutableToolDedupes FROM
  /// "TurnMetrics" WHERE "mutableToolDedupes" > 0;`
  mutableToolDedupes         Int      @default(0)
  /// [v1.4.2 — Day 3 / Spec Item 3] Per-yield UUID emitted by the engine
  /// on `pending_action`. Nullable because (a) turns without a write
  /// never yield one and (b) pre-migration rows have no value. The
  /// resume route's `prisma.turnMetrics.updateMany` keys on this column
  /// instead of `(sessionId, turnIndex)` to eliminate the cross-attempt
  /// false-resolution that pair allows when the same turn yields a
  /// second pending action (e.g. modifiable-field re-yield). Indexed
  /// because resume is a per-row lookup and the column is sparse.
  attemptId                  String?
  /// [v1.4.2 — Day 3] `true` when this turn was driven by a
  /// pre-fetch / synthetic intent (e.g. resumed-session snapshot reads)
  /// rather than a user prompt. Lets dashboards exclude synthetic
  /// turns from latency / cost percentiles without losing the
  /// instrumentation row.
  synthetic                  Boolean  @default(false)
  /// [v1.4.2 — Day 3] Wall-clock ms reported by the host for the
  /// client-side write tool execution (signing + broadcast +
  /// indexer-lag absorption). Written only on resume; null on the
  /// initial chat row that yielded the `pending_action`.
  writeToolDurationMs        Int?
  /// [v1.4.2 — Day 3] Estimated USD savings from prompt-cache reads on
  /// this turn — `cacheReadTokens * (input_rate - cacheRead_rate)` per
  /// `costRatesForModel`. Reported separately from `estimatedCostUsd`
  /// so dashboards can attribute hit-rate value without subtraction.
  cacheSavingsUsd            Float    @default(0)
  /// [v1.4.2 — Day 3] Phase of the turn that produced this row:
  /// `'initial'` for the chat-route close, `'resume'` for the row the
  /// resume-route close writes when the user resolves the pending
  /// action. Default `'initial'` is the safe value for backfilled
  /// pre-migration rows (none of them carried a resume row).
  turnPhase                  String   @default("initial")
  /// [SPEC 8 v0.5.1 B3.6 / Layer 6] One-shot per-turn shape declared by
  /// the engine `harness_shape` event: `'lean' | 'standard' | 'rich' |
  /// 'max'`. Null on rows that pre-date the engine event (engines
  /// older than v1.5.0). Drives the dashboard segmentation that
  /// catches LEAN-turn regressions (any `thinkingBlockCount > 0` on a
  /// `harnessShape='lean'` row is a shape-contract violation worth
  /// investigating).
  ///
  /// [P4.1 follow-up — 2026-05-25] `todoUpdateCount` companion field
  /// dropped — `update_todo` tool deleted in engine v3.0.0; the column
  /// was always 0 post-migration and no longer informs the lean
  /// regression signal.
  harnessShape               String?
  /// [SPEC 8 v0.5.1 B3.6] Count of `thinking_done` events emitted this
  /// turn. Soft-capped per shape (lean=0, standard=3, rich=5, max=8).
  thinkingBlockCount         Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6] Time To First Visible Progress — ms from
  /// turn start to the first host-renderable event (`thinking_delta`,
  /// `tool_start`, or `text_delta`, whichever first).
  /// Null when the turn produced no renderable events (rare error
  /// path). p50 ≤ 1500ms is the SPEC 8 v0.5.1 B3.7 rollout gate.
  ttfvpMs                    Int?
  /// [SPEC 8 v0.5.1 B3.6] Output tokens for `text_delta` events only
  /// (excludes thinking + tool I/O). Approximated as
  /// `Math.ceil(charCount / 4)` to match `@t2000/engine` `estimateTokens`.
  /// Canonical terseness signal — p50 ≤ baseline + 50% is the
  /// final-text-discipline rollout gate.
  finalTextTokens            Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / G9] Raw count of `<eval_summary>` markers
  /// parsed by the engine (`thinking_done.summaryMode === true`).
  /// No quality judgment — dashboard derives the appropriately-emitted
  /// rate from `WHERE harnessShape >= 'standard'`. Should be 0 on lean.
  evalSummaryEmittedCount    Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / G9] Increments when `evalSummaryEmittedCount
  /// > 1` in the same turn (multiple markers — broken trust-card UX).
  /// Should be ~zero in steady state.
  evalSummaryViolationsCount Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / D2] True when a `pending_input` event arrived
  /// on a session pinned to the legacy harness. Should ALWAYS be false
  /// in production under engine v1.5.0 (which doesn't emit
  /// `pending_input`); non-zero means session pinning broke or a SPEC
  /// 9 v0.1.2 emission leaked into a legacy session.
  pendingInputSeenOnLegacy   Boolean  @default(false)
  /// [SPEC 8 v0.5.1 B3.6] Count of `tool_progress` events emitted by
  /// long-running tools this turn. Spec target: ≥80% of swap_execute
  /// turns emit at least one progress event once the wiring lands.
  toolProgressEventCount     Int      @default(0)
  /// [SPEC 8 v0.5.1 B3.6 / Gap J] 1 when the turn ended without
  /// `turn_complete` AND without `pending_action` (interrupted —
  /// client abort, serverless timeout, network drop). Rollback gate:
  /// >1% over 24h triggers SPEC 8 v0.5.1 B3.7 flag rollback.
  interruptedMessageCount    Int      @default(0)
  /// [SPEC 20.2 / D-1 (a)] Serialized Cetus route captured at swap_quote
  /// time and threaded through pending_action.cetusRoute. Persisted here
  /// so the resume route can rehydrate it onto the rebuilt PendingAction
  /// (audric's session store is in-memory; this column is the durable
  /// snapshot). Audric's prepare-route uses it as the fast-path: skips
  /// the ~400-500ms Cetus findSwapRoute() re-discovery when fresh + coin
  /// types match, falls back to fresh discovery on mismatch / staleness
  /// (D-2 verification + D-3 TTL re-validation). Null on rows from non-
  /// swap turns and on pre-SPEC-20.2 sessions (D-5 dual-path fallback).
  cetusRoute                 Json?
  /// [S.155 / D-4 / 2026-05-18] Persisted `StreamResumeOutcome` payload
  /// from the engine v2.5.0 `onStreamResume` callback. Discriminated-union
  /// JSON shape mirroring `@t2000/engine`'s `StreamResumeOutcome` type:
  ///
  ///   - `{ outcome: 'clean', streamId, eventsReplayed }`
  ///   - `{ outcome: 'synthesized_terminal', streamId, eventsReplayed }`
  ///   - `{ outcome: 'mid_tool', streamId, eventsReplayed, toolUseId, toolName }`
  ///   - `{ outcome: 'empty', streamId }`
  ///   - `{ outcome: 'replay_error', streamId, errorMessage }`
  ///     (note: `Error` objects don't `JSON.stringify` cleanly, so the
  ///     `replay_error` variant flattens to `errorMessage: string` — same
  ///     normalization the `[stream-resume]` console.log applies in
  ///     `app/api/engine/chat/route.ts`.)
  ///
  /// `null` on the overwhelming majority of rows — only set when the chat
  /// route was invoked with `resumeStreamId` (page-reload mid-stream
  /// recovery path). Companion to the structured `[stream-resume]` Vercel
  /// log: the log is the first defense for ops (greppable, no DB needed),
  /// the column is the durable signal for dashboarding (`SELECT
  /// "streamResumeOutcome"->>'outcome' AS outcome, COUNT(*) FROM
  /// "TurnMetrics" WHERE "streamResumeOutcome" IS NOT NULL GROUP BY 1`).
  ///
  /// Used to evaluate the trigger for Path A (silent in-flight tool re-
  /// execution) — Decision 6 in SPEC 37 v0.7a Phase 5 Slice C lock. Path A
  /// builds if `mid_tool` resumes exceed ~5% of total resumes over 7d
  /// AND a specific tool dominates the toolName histogram (`SELECT
  /// "streamResumeOutcome"->>'toolName' AS tool, COUNT(*) FROM
  /// "TurnMetrics" WHERE "streamResumeOutcome"->>'outcome' = 'mid_tool'
  /// GROUP BY 1 ORDER BY 2 DESC`).
  streamResumeOutcome        Json?
  createdAt                  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([effortLevel, modelUsed])
  @@index([createdAt])
  @@index([attemptId])
  @@index([harnessShape])
}

// [S.375 — 2026-06-07] `UserFinancialContext` model REMOVED. It backed the
// daily `<financial_context>` orientation snapshot, killed in S.375. Post-
// S.373 the row held only 4 stable fields (currentApy / pendingAdvice /
// recentActivity / daysSinceLastSession); pendingAdvice duplicated AdviceLog,
// recentActivity + currentApy were tool-covered, and daysSinceLastSession is
// trivially inline — the daily `getPortfolio()` BlockVision-fan-out cron +
// table didn't earn their keep. The LLM now orients via tools. Table dropped
// via migration `20260607010000_s375_drop_user_financial_context`.

// ===========================================================================
// v0.7e Persistent Chats (S.247) — replaces the drizzle Chat/Message/Vote
// stack at `apps/web-v2/lib/db/{schema,queries,migrations}` per LOCK-1
// (prisma rewrite). Document / Suggestion / Stream tables from the template
// are intentionally NOT ported (LOCK-2 strip).
//
// [Corrected 2026-06-09 / S.390 audit] Resume-on-reload is handled by the
// Redis-backed `resumable-stream` package (`lib/resumable-stream.ts`) keyed
// on the `Chat.activeStreamId` column — NOT a ported Stream table, and NOT
// the engine's `StreamCheckpointStore`. The earlier "engine StreamCheckpointStore
// owns resume-on-reload per LOCK-4" claim was false: that engine path was
// DEFERRED and never wired (it appends raw `EngineEvent`s, but web-v2's wire
// format is AI SDK `UIMessage` chunks — not interchangeable). The engine
// checkpoint surface is dead across all consumers (audit §3).
//
// FK choice: Chat → User.suiAddress (not User.id) because session.user.id
// post-zkLogin = canonical Sui address per `audric-auth.ts:289`. Routing
// via suiAddress avoids a lookup hop on every chat-save.
//
// Title field is nullable on first insert: route persists with `null`
// title, kicks off async Haiku summarizer (LOCK-5), updates the row when
// title returns. Sidebar shows "Generating title…" or first-50-chars
// fallback while null.
// ===========================================================================

model Chat {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  title          String?
  visibility     String    @default("private") // "private" | "public"
  userSuiAddress String
  // [SPEC_AUDRIC_STREAM_RESUME Phase 1, 2026-05-24] Tracks the
  // currently-active resumable-stream id for this chat. Set by the
  // POST /api/chat handler's `consumeSseStream` callback when a new
  // stream starts; cleared by `onFinish` on natural completion OR
  // by POST /api/chat/[id]/stop on explicit cancel. GET
  // /api/chat/[id]/stream reads this to decide between 204 (no
  // active stream) and resumeExistingStream(). Nullable — most
  // chats have no in-flight stream at rest.
  activeStreamId String?
  user           User      @relation(fields: [userSuiAddress], references: [suiAddress], onDelete: Cascade)
  messages       Message[]
  votes          Vote[]

  @@index([userSuiAddress, createdAt])
  @@index([visibility])
}

model Message {
  id          String   @id @default(uuid())
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        String // "user" | "assistant"
  parts       Json
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())
  votes       Vote[]

  @@index([chatId, createdAt])
}

model Vote {
  chatId    String
  messageId String
  isUpvoted Boolean
  chat      Chat    @relation(fields: [chatId], references: [id], onDelete: Cascade)
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([chatId, messageId])
}
