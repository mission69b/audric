# ─── web-v2 environment ─────────────────────────────────────────────
#
# Every var below is validated at server boot via `lib/env.ts` (Zod
# schema). Missing or empty values fail loudly with an actionable
# error — see the env-validation-gate rule in t2000/.cursor/rules.
#
# Required vars throw at boot if missing/empty. Optional vars are
# `string | undefined` at the call site.

# ─── Required (server) ───────────────────────────────────────────────

# Postgres connection string for Prisma — Phase 2 P2.0c points this at
# the same NeonDB as audric/web.
DATABASE_URL=****

# Anthropic Claude API key — powers every LLM call. Required UNTIL
# Day 2c switches to AI_GATEWAY_API_KEY via gateway() wrapper.
ANTHROPIC_API_KEY=****

# ─── Optional (server) ───────────────────────────────────────────────

# Vercel AI Gateway API key — required only once Day 2c wires the
# gateway() wrapper around the engine model.
# https://vercel.com/ai-gateway
# AI_GATEWAY_API_KEY=****

# Vercel Blob — required only if the template's /api/files/upload route
# is ever exercised (Phase 5+ migration; not needed for Day 2a-2e).
# https://vercel.com/docs/vercel-blob
# BLOB_READ_WRITE_TOKEN=****

# Redis — required only when /api/chat enables resumable-stream
# checkpointing. Pre-existing template feature; not Day 2a-2e gated.
# https://vercel.com/docs/redis
# REDIS_URL=****

# ─── Required (client / NEXT_PUBLIC_*) ───────────────────────────────

# Google OAuth client id for zkLogin. Used by verifyJwt to check the
# JWT audience claim. Same value as apps/web's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=****

# Enoki public API key (zkLogin + gas sponsorship). Treated as a
# publishable key by Enoki — safe to ship to clients. Same value as
# apps/web's NEXT_PUBLIC_ENOKI_API_KEY.
NEXT_PUBLIC_ENOKI_API_KEY=****
