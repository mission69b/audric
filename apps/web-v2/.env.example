# Phase 2 will add zkLogin env vars here (GOOGLE_OAUTH_CLIENT_ID, ENOKI_API_KEY,
# etc — port from `apps/web/.env.example`). The template's `AUTH_SECRET` was
# removed during Day 1c (Auth.js eviction); web-v2 does not use next-auth.

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
